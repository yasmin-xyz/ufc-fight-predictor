# Copy to .env.local and fill in real values. Never commit .env.local.

# AI providers (server-only — used by /api/predict)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# The Odds API (server-only — used by app/lib/oddsProvider.ts)
ODDS_API_KEY=

# Cito (UFC fighter stats/history provider, server-only)
CITO_API_KEY=

# Supabase (server-only — service role, bypasses RLS)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Long random secret for the admin fighter-sync route
# (Authorization: Bearer <value>). Generate with e.g. `openssl rand -hex 32`.
FIGHTER_SYNC_SECRET=
